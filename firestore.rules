rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    match /test/{testId} {
      allow read, write: if false; // Denying it because the test expects to fail or succeed, an auth error won't crash it. But we actually just want to see if the connection is made. Getting a permission denied is totally fine to test connection!
    }
  }
}
